# Schwab API
SCHWAB_APP_KEY=your_app_key
SCHWAB_APP_SECRET=your_app_secret
SCHWAB_CALLBACK_URL=https://127.0.0.1
SCHWAB_TOKEN_PATH=secrets/schwab_token.json
SCHWAB_ACCOUNT_ID=

# Symbols
SPY_SYMBOL=SPY
VIX_SYMBOL=$VIX

# IBKR
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=19
IBKR_ACCOUNT=
IBKR_EXCHANGE=SMART
IBKR_CURRENCY=USD

# Bot runtime
DRY_RUN=true
BOT_TIMEZONE=America/New_York
POLLING_SECONDS=45

# Strategy
BAR_MINUTES=1
LOOKBACK_BARS=390
RETRAIN_EVERY_N_CYCLES=30
MIN_TRAIN_ROWS=120
TARGET_HORIZON_BARS=5
LONG_THRESHOLD=0.58
SHORT_THRESHOLD=0.42
NEUTRAL_BAND=0.03
MAX_POSITION_DOLLARS=25000
RISK_PER_TRADE=0.003
MAX_DAILY_LOSS=1500
MAX_TRADES_PER_DAY=10
STOP_ATR_MULTIPLE=1.8
TAKE_PROFIT_ATR_MULTIPLE=2.4
VIX_CIRCUIT_BREAKER=35
